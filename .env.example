# Copy to .env and adjust. .env is gitignored — NEVER commit real values.
# `make secrets` transforms this file into the k8s Secrets the cluster consumes.

# --- In-cluster stores (any non-empty value works locally) ---
POSTGRES_PASSWORD=localdev-postgres
API_DB_PASSWORD=localdev-api-db
USER_SERVICE_DB_PASSWORD=localdev-user-service-db
VALKEY_PASSWORD=localdev-valkey
MINIO_ROOT_USER=chatbot
MINIO_ROOT_PASSWORD=localdev-minio-secret
VAULT_DEV_ROOT_TOKEN=localdev-vault-root

# --- External services (fill in when the slice that needs them lands) ---
# LLM providers — required from slice 3 (bare chat turn) onward
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Auth0 — required from slice 5 (login) onward
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
# Session cookie signing/encryption secret for the BFF (generate: openssl rand -hex 32)
SESSION_SECRET=
