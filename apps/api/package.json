{
  "name": "@chatbot/api",
  "version": "0.1.0",
  "private": true,
  "description": "Domain core — chat orchestration, LLM adapters, conversation data (NestJS)",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "jest"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {}
      ]
    },
    "testEnvironment": "node"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@google/genai": "^2.8.0",
    "@grpc/grpc-js": "^1.14.4",
    "@grpc/proto-loader": "^0.8.1",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.26",
    "@nestjs/core": "^11.1.26",
    "@nestjs/microservices": "^11.1.26",
    "@nestjs/platform-express": "^11.1.26",
    "@nestjs/terminus": "^11.1.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/instrumentation-express": "^0.67.0",
    "@opentelemetry/instrumentation-grpc": "^0.219.0",
    "@opentelemetry/instrumentation-http": "^0.219.0",
    "@opentelemetry/instrumentation-ioredis": "^0.67.0",
    "@opentelemetry/instrumentation-pg": "^0.71.0",
    "@opentelemetry/instrumentation-pino": "^0.65.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "bullmq": "^5.78.0",
    "ioredis": "^5.11.1",
    "minio": "^8.0.7",
    "nestjs-pino": "^4.6.1",
    "openai": "^6.42.0",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.26",
    "@testcontainers/postgresql": "^12.0.1",
    "@testcontainers/redis": "^12.0.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "jest": "^30.4.2",
    "supertest": "^7.2.2",
    "testcontainers": "^12.0.3",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  }
}
